<?xml version="1.0" encoding="utf-8"?>
<!-- Widget Layout - Simple & Safe Version -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FFFFFF">

    <!-- Header Simple -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📅 Aturin"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#5263F3" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hari ini"
            android:textSize="12sp"
            android:textColor="#666666" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="8dp" />

    <!-- Content Area - Fixed Height -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="vertical">

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="32sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tidak ada jadwal"
                android:textSize="14sp"
                android:textColor="#666666"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Belum ada aktivitas hari ini"
                android:textSize="12sp"
                android:textColor="#999999" />

        </LinearLayout>

        <!-- Schedule Items - Simple List -->
        <LinearLayout
            android:id="@+id/schedule_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Item 1 -->
            <LinearLayout
                android:id="@+id/item_1_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:background="#F5F5F5"
                android:visibility="gone">

                <TextView
                    android:id="@+id/item_1_time"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="08:00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5263F3"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/item_1_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Meeting"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/item_1_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:id="@+id/item_2_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:background="#F5F5F5"
                android:visibility="gone">

                <TextView
                    android:id="@+id/item_2_time"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="09:00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5263F3"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/item_2_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Task"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/item_2_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:id="@+id/item_3_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:background="#F5F5F5"
                android:visibility="gone">

                <TextView
                    android:id="@+id/item_3_time"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="10:00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5263F3"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/item_3_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Activity"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/item_3_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Footer Simple -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/widget_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 aktivitas, 0 tugas"
            android:textSize="11sp"
            android:textColor="#999999" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↗️"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>
