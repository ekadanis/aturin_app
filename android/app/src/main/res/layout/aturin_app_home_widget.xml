<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/app_icon"
            android:contentDescription="Aturin App Icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Aturin"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#5263F3" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hari ini"
            android:textSize="12sp"
            android:textColor="#666666" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="8dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_event_note"
            android:alpha="0.5"
            android:contentDescription="No schedule icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tidak ada jadwal"
            android:textSize="14sp"
            android:textColor="#666666"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Belum ada aktivitas atau tugas hari ini"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center" />

    </LinearLayout>

    <!-- Schedule List -->
    <ScrollView
        android:id="@+id/schedule_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/schedule_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Item 1 -->
            <LinearLayout
                android:id="@+id/item_1_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/item_1_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#5263F3" />

                    <View
                        android:id="@+id/item_1_indicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/item_indicator"
                        android:backgroundTint="#5263F3" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/item_1_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Judul Item"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/item_1_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Kategori"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:background="@drawable/category_background"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/item_1_type_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_task"
                    android:contentDescription="Item type" />

            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:id="@+id/item_2_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/item_2_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#5263F3" />

                    <View
                        android:id="@+id/item_2_indicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/item_indicator"
                        android:backgroundTint="#5263F3" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/item_2_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Judul Item"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/item_2_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Kategori"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:background="@drawable/category_background"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/item_2_type_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_activity"
                    android:contentDescription="Item type" />

            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:id="@+id/item_3_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/item_3_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10:00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#5263F3" />

                    <View
                        android:id="@+id/item_3_indicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/item_indicator"
                        android:backgroundTint="#5263F3" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/item_3_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Judul Item"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/item_3_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Kategori"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:background="@drawable/category_background"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/item_3_type_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_task"
                    android:contentDescription="Item type" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/widget_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 aktivitas, 0 tugas"
            android:textSize="11sp"
            android:textColor="#999999" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buka App"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#5263F3"
            android:background="?android:attr/selectableItemBackground"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
